# iRingo WeatherKit Arg - Anywhere MITM RuleSet
# 上游: NSRingo/WeatherKit（作者 VirgilClyne、WordlessEcho、001；v3.2.0-beta1）。

name = iRingo WeatherKit Arg
hostname = weatherkit.apple.com

[Parameter]
1, 0, weather_provider, "[天气] 数据源", 使用选定的数据源替换天气数据。, ColorfulClouds, "[ColorfulClouds, WeatherKit, QWeather]"
1, 0, next_hour_provider, "[未来一小时降水强度] 数据源", 使用选定的数据源填充未来一小时降水强度的数据。, ColorfulClouds, "[ColorfulClouds, WeatherKit, QWeather]"
1, 0, air_quality_algorithm, "[iRingo内置算法] 算法", 通过污染物数据本地计算空气指数。, EU_EAQI, "[EU_EAQI, None, UBA, WAQI_InstantCast_US, WAQI_InstantCast_CN, WAQI_InstantCast_CN_25_DRAFT]"
0, 0, colorfulclouds_token, "[API] 彩云天气令牌", "彩云天气 API 令牌。", 
0, 0, qweather_host, "[API] 和风天气主机", "和风天气 API 使用的主机名。", devapi.qweather.com
0, 0, qweather_token, "[API] 和风天气令牌", "和风天气 API 令牌。", 
0, 0, waqi_token, "[API] WAQI 令牌", "填写此字段将自动使用 WAQI 高级 API。", 
1, 0, log_level, "[调试] 日志等级", 选择脚本日志的输出等级。, WARN, "[WARN, OFF, ERROR, INFO, DEBUG, ALL]"

[Rule]
1, 100, ^https://[^/]+/api/v1/availability/, 
1, 100, ^https://[^/]+/api/v2/weather/, 
