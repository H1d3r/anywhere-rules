# Bilibili 去广告 - Anywhere MITM RuleSet
# 上游: kokoryh/Sparkle + kokoryh/Script。

name = Bilibili去广告
hostname = grpc.biliapi.net, app.bilibili.com, api.bilibili.com, api.live.bilibili.com, line3-h5-mobile-api.biligame.com

[Parameter]
1, 0, display_up_list, "[动态] UP 列表", "还原上游 displayUpList，可控制动态页顶部 UP 列表展示方式。", show, "[show, auto, hide]"
1, 0, purify_comment, "[评论] 净化评论", 过滤评论区广告卡片和常见引流内容。, true, "[true, false]"
1, 0, log_level, "[调试] 日志等级", "选择上游 protobuf 脚本日志等级。", error, "[error, off, warn, info, debug]"

[Rule]

0, 2, ^https://grpc\.biliapi\.net/bilibili\.app\.(?:interface\.v1\.(?:Teenagers/ModeStatus|Search/DefaultWords)|view\.v1\.View/TFInfo|viewunite\.v1\.View/(?:PlayPause|ViewEndPage))(?:\?|$), grpc-accept-encoding
0, 1, ^https://grpc\.biliapi\.net/bilibili\.app\.(?:interface\.v1\.(?:Teenagers/ModeStatus|Search/DefaultWords)|view\.v1\.View/TFInfo|viewunite\.v1\.View/(?:PlayPause|ViewEndPage))(?:\?|$), grpc-accept-encoding, identity
0, 2, ^https://grpc\.biliapi\.net/bilibili\.app\.(?:interface\.v1\.(?:Teenagers/ModeStatus|Search/DefaultWords)|view\.v1\.View/TFInfo|viewunite\.v1\.View/(?:PlayPause|ViewEndPage))(?:\?|$), grpc-encoding
0, 1, ^https://grpc\.biliapi\.net/bilibili\.app\.(?:interface\.v1\.(?:Teenagers/ModeStatus|Search/DefaultWords)|view\.v1\.View/TFInfo|viewunite\.v1\.View/(?:PlayPause|ViewEndPage))(?:\?|$), grpc-encoding, identity
0, 0, ^https://[^/]+/x/(?:resource/(?:top/activity|patch/tab(?:/v2)?)|v2/search/square|vip/ads/materials)(?:\?|$), 2, "{""code"":-404,""message"":""-404"",""ttl"":1,""data"":null}"
0, 0, ^https://[^/]+/pgc/activity/deliver/material/receive(?:\?|$), 2, "{""code"":0,""data"":{""closeType"":""close_win"",""container"":[],""showTime"":""""},""message"":""success""}"
0, 0, ^https://[^/]+/xlive/e-commerce-interface/v1/ecommerce-user/get_shopping_info(?:\?|$), 2, {}
0, 0, ^https://[^/]+/game/live/large_card_material(?:\?|$), 2, "{""code"":0,""message"":""success""}"
1, 5, ^https://[^/]+/x/resource/show/tab/v2(?:\?|$), delete, $.data.splash
1, 5, ^https://[^/]+/x/resource/show/tab/v2(?:\?|$), delete, $.data.top_more
1, 5, ^https://[^/]+/pgc/view/v2/app/season(?:\?|$), delete, $.data.payment
1, 1, ^https://grpc\.biliapi\.net/bilibili\.app\.(?:interface\.v1\.(?:Teenagers/ModeStatus|Search/DefaultWords)|view\.v1\.View/TFInfo|viewunite\.v1\.View/(?:PlayPause|ViewEndPage))(?:\?|$), grpc-status, 0
1, 100, ^https://grpc\.biliapi\.net/bilibili\.app\.(?:interface\.v1\.(?:Teenagers/ModeStatus|Search/DefaultWords)|view\.v1\.View/TFInfo|viewunite\.v1\.View/(?:PlayPause|ViewEndPage))(?:\?|$), 
1, 100, ^https://[^/]+/(?:pgc/page/channel|x/v2/splash/(?:list|show|event/list2)|x/resource/show/(?:tab/v2|skin)|x/v2/account/(?:mine(?:/ipad)?|myinfo)|xlive/(?:app-interface/v2/index/feed|app-room/v1/index/getInfoBy(?:Room|User))|x/pd-proxy/tracker)(?:\?|$), 
1, 100, ^https://[^/]+/x/v2/feed/index(?:/story)?(?:\?|$), 
1, 100, ^https://[^/]+/bilibili\.(?:app\.(?:show\.v1\.Popular/Index|dynamic\.v2\.Dynamic/DynAll|view(?:unite)?\.v1\.View/(?:View|ViewProgress|RelatesFeed)|playurl\.v1\.PlayURL/PlayView|playerunite\.v1\.Player/PlayViewUnite)|polymer\.app\.search\.v1\.Search/SearchAll|community\.service\.dm\.v1\.DM/DmView|main\.community\.reply\.v1\.Reply/MainList|pgc\.gateway\.player\.v2\.PlayURL/PlayView)(?:\?|$), 
