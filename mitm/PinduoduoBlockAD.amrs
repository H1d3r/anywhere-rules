# 拼多多去广告 - Anywhere MITM RuleSet
# 功能: 去开屏、首页全局挂件、多多买菜 waybill 红包商品列表。

name = 拼多多去广告
hostname = api.pinduoduo.com, api.yangkeduo.com, mobile.yangkeduo.com

0, 2, ^/proxy/api/api/express/post/waybill/red_packet/goods_list$, accept-encoding
0, 1, ^/proxy/api/api/express/post/waybill/red_packet/goods_list$, accept-encoding, identity
0, 4, ^/api/(?:cappuccino/splash|aquarius/hungary/global/homepage\?), 
1, 4, ^/proxy/api/api/express/post/waybill/red_packet/goods_list$, 
